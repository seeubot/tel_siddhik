# ─── Signaling Server (.env) ─────────────────────────────────────────────────
PORT=3001

# URL of the API server (used internally for ban checks if needed)
API_SERVER_URL=https://your-api-server.koyeb.app


# ─── API Server (.env) ────────────────────────────────────────────────────────
PORT=3002

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/mayaconnect?retryWrites=true&w=majority

# Allowed frontend origin (your PWA domain)
FRONTEND_URL=https://your-pwa.koyeb.app


# ─── Frontend (.env) ──────────────────────────────────────────────────────────
# WebSocket URL of the signaling server (use wss:// in production)
REACT_APP_SIGNALING_URL=wss://your-signaling-server.koyeb.app

# HTTP URL of the API server
REACT_APP_API_URL=https://your-api-server.koyeb.app

# Metered.ca TURN credentials (free tier — sign up at metered.ca)
REACT_APP_TURN_URL=turn:relay.metered.ca:80
REACT_APP_TURN_USERNAME=your_metered_username
REACT_APP_TURN_CREDENTIAL=your_metered_credential
